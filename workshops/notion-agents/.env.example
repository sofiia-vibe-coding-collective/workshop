# ─────────────────────────────────────────────────
# Notion Agent Workshop — .env
# Copy to .env and fill in your API keys.
# ─────────────────────────────────────────────────

# 1. Google AI Studio API key (for image generation)
#    Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 2. ElevenLabs API key (for audio + sound effects)
#    Get one at: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# 3. Public base URL of this server.
#    Local dev: http://localhost:8000
#    Deployed (Railway/Render/etc.): https://your-app.railway.app
#    NO trailing slash.
PUBLIC_BASE_URL=http://localhost:8000

# 4. Port to listen on (default 8000)
PORT=8000

# 5. Days to keep generated files before auto-deletion (default 7)
STATIC_MAX_AGE_DAYS=7
